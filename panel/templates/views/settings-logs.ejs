<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Logs: <%= label %> – UPGS Panel</title>
  <%- include('partials/nav-styles') %>
  <style>
    h1 { font-size: 1.25rem; }
    .back { margin-bottom: 1rem; }
    .back a { color: var(--color-primary); text-decoration: none; }
    .back a:hover { text-decoration: underline; }
    .log-box { background: var(--color-primary-dark); color: #d8f3dc; padding: 1rem; border-radius: var(--radius); overflow-x: auto; font-family: ui-monospace, monospace; font-size: 0.8rem; line-height: 1.4; white-space: pre-wrap; word-break: break-all; max-height: 70vh; overflow-y: auto; }
    .log-box.error { background: #3d0f0f; color: #f8d7da; }
    .meta { font-size: 0.85rem; color: var(--color-muted); margin-bottom: 0.75rem; }
  </style>
</head>
<body>
  <%- include('partials/nav') %>
  <main id="main">
    <div class="back"><a href="/settings">← Settings</a></div>
    <h1>Logs: <%= label %></h1>
    <p class="meta">Unit: <code><%= unit %></code> · Last 300 lines<%= typeof priority !== 'undefined' && priority === 'err' ? ' (errors only)' : '' %> from journalctl</p>
    <% const safeOutput = typeof output !== 'undefined' ? String(output).replace(/</g, '&lt;').replace(/>/g, '&gt;') : '(no output)'; %>
    <div class="log-box <%= typeof error !== 'undefined' && error ? 'error' : '' %>"><%= safeOutput %></div>
  </main>
</body>
</html>
