<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mail – UPGS Panel</title>
  <%- include('../partials/nav-styles') %>
  <style>
    .risk.risk-warn { background: #fff3cd; border-left-color: #ffc107; color: #856404; }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>
  <main id="main">
    <h1>Mail</h1>
    <% if (typeof mailError === 'string' && mailError) { %>
    <div class="error-msg"><%= mailError %></div>
    <% } %>
    <div class="risk risk-warn"><strong>Risk:</strong> Mail may not be delivered or may be marked as spam. Ensure DNS (SPF/DKIM/DMARC) and firewall (ports 25, 587) are configured for this server.</div>
    <form method="post" action="/mail/domains" class="form-inline" style="margin-bottom:1rem;">
      <label for="mail-domain" class="sr-only">Mail domain</label>
      <input type="text" id="mail-domain" name="domain" placeholder="Mail domain (e.g. example.com)" required>
      <button type="submit" class="btn">Add domain</button>
    </form>
    <div class="table-scroll-wrap">
    <table>
      <thead><tr><th>Domain</th><th>Mailboxes</th></tr></thead>
      <tbody>
        <% domains.forEach(function(d) { %>
        <tr><td><%= d.domain %></td><td><%= d.mailbox_count %></td></tr>
        <% }); %>
        <% if (!domains.length) { %><tr><td colspan="2">No mail domains yet.</td></tr><% } %>
      </tbody>
    </table>
    </div>
  </main>
</body>
</html>
