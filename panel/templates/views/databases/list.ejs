<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Databases – UPGS Panel</title>
  <%- include('../partials/nav-styles') %>
  <style>
    .risk.risk-warn { background: var(--color-warn-bg); border-left-color: var(--color-warn-border); color: #5c4d1f; }
    .form-row { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: flex-end; margin-bottom: 0.5rem; }
    .form-row input[type="text"], .form-row input[type="password"] { min-width: 140px; }
    .form-row select { min-width: 120px; }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>
  <main id="main">
    <h1>Databases</h1>
    <p class="intro">Create MySQL/MariaDB databases and users for your applications.</p>
    <% if (typeof hasMysqlPassword !== 'undefined' && !hasMysqlPassword) { %>
    <div class="risk risk-warn">Set the MySQL root password in <a href="/settings">Settings</a> so the panel can create databases and users on the server.</div>
    <% } %>
    <% if (typeof repair !== 'undefined' && repair === 'ok') { %>
    <div class="success-msg">Database repair completed.</div>
    <% } %>
    <% if (typeof repair !== 'undefined' && repair === 'error') { %>
    <div class="error-msg">Repair failed.<% if (typeof repairMsg !== 'undefined' && repairMsg) { %> <%= repairMsg %><% } %></div>
    <% } %>
    <% if (typeof dbError === 'string' && dbError) { %>
    <div class="error-msg"><%= dbError %></div>
    <% } %>
    <% if (typeof userError === 'string' && userError) { %>
    <div class="error-msg"><%= userError %></div>
    <% } %>
    <div class="card">
      <h2><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>Create database</h2>
      <form method="post" action="/databases/databases">
        <div class="form-row">
          <div>
            <label for="db-name">Database name</label>
            <input type="text" id="db-name" name="name" placeholder="e.g. myapp_db" required>
          </div>
          <div>
            <label for="db-site">Assign to site</label>
            <select id="db-site" name="site_id">
              <option value="">— None —</option>
              <% if (typeof sites !== 'undefined' && sites.length) { sites.forEach(function(s) { %><option value="<%= s.id %>"><%= s.domain %></option><% }); } %>
            </select>
          </div>
          <button type="submit" class="btn">Create</button>
        </div>
      </form>
    </div>
    <div class="card">
      <h2><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>Create user</h2>
      <form method="post" action="/databases/users">
        <div class="form-row">
          <div>
            <label for="user-username">Username</label>
            <input type="text" id="user-username" name="username" placeholder="Username" required>
          </div>
          <div>
            <label for="user-password">Password</label>
            <input type="password" id="user-password" name="password" placeholder="Password">
          </div>
          <div>
            <label for="user-host">Host</label>
            <input type="text" id="user-host" name="host" value="localhost" placeholder="Host">
          </div>
          <button type="submit" class="btn">Create user</button>
        </div>
        <p class="risk"><strong>Risk:</strong> Using host <code>%</code> allows connections from any host; use <code>localhost</code> when possible.</p>
      </form>
    </div>
    <% if (databases.length && users.length) { %>
    <div class="card">
      <h2><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><path d="M12 11a4 4 0 100-8 4 4 0 000 8z"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>Assign user to database</h2>
      <form method="post" action="/databases/grants">
        <div class="form-row">
          <div>
            <label for="grant-db">Database</label>
            <select id="grant-db" name="database_id" required>
              <option value="">Select database</option>
              <% databases.forEach(function(d) { %><option value="<%= d.id %>"><%= d.name %></option><% }); %>
            </select>
          </div>
          <div>
            <label for="grant-user">User</label>
            <select id="grant-user" name="db_user_id" required>
              <option value="">Select user</option>
              <% users.forEach(function(u) { %><option value="<%= u.id %>"><%= u.username %>@<%= u.host %></option><% }); %>
            </select>
          </div>
          <div>
            <label for="grant-priv">Privileges</label>
            <select id="grant-priv" name="privileges">
              <option value="ALL">All</option>
              <option value="READ_WRITE">Read + Write</option>
              <option value="READ_ONLY">Read only</option>
            </select>
          </div>
          <button type="submit" class="btn">Assign</button>
        </div>
      </form>
    </div>
    <% } %>
    <h2 class="section-title"><svg class="ic" viewBox="0 0 24 24"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>Databases</h2>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Name</th><th>Site</th><th>Size</th><th>Users with access</th><th>Actions</th></tr></thead>
        <tbody>
          <% databases.forEach(function(d) {
            var dbGrants = typeof grants !== 'undefined' ? grants.filter(function(g){ return g.database_id === d.id; }) : [];
            var sizeStr = (typeof databaseSizes !== 'undefined' && databaseSizes[d.name]) ? databaseSizes[d.name] : '—';
          %>
          <tr>
            <td><strong><%= d.name %></strong></td>
            <td><% if (d.site_id && d.site_domain) { %><a href="/sites/<%= d.site_id %>"><%= d.site_domain %></a><% } else { %>—<% } %></td>
            <td><%= sizeStr %></td>
            <td>
              <div class="grant-list">
                <% if (dbGrants.length) { dbGrants.forEach(function(gr) { %>
                <span><%= gr.username %>@<%= gr.host %></span><span class="privilege-badge"><%= gr.privileges %></span>
                <form method="post" action="/databases/grants/revoke" class="revoke-form" data-confirm="Revoke <%= gr.username %> access to <%= d.name %>?">
                  <input type="hidden" name="database_id" value="<%= gr.database_id %>">
                  <input type="hidden" name="db_user_id" value="<%= gr.db_user_id %>">
                  <button type="submit" class="btn btn-small btn-danger">Revoke</button>
                </form>
                <% }); } else { %><span class="empty-msg">No users assigned</span><% } %>
              </div>
            </td>
            <td>
              <div class="action-group">
                <a href="/databases/databases/<%= d.id %>/download" class="btn btn-small">Download .sql.gz</a>
                <form method="post" action="/databases/databases/<%= d.id %>/repair" class="inline">
                  <button type="submit" class="btn btn-small btn-secondary">Repair</button>
                </form>
                <form method="post" action="/databases/databases/<%= d.id %>/delete" class="inline" data-confirm="Delete database <%= d.name %>? This will DROP the database in MySQL. Cannot be undone.">
                  <button type="submit" class="btn btn-small btn-danger">Delete</button>
                </form>
              </div>
            </td>
          </tr>
          <% }); %>
          <% if (!databases.length) { %><tr><td colspan="5" class="empty-msg">None yet. Create one above.</td></tr><% } %>
        </tbody>
      </table>
    </div>
    <h2 class="section-title"><svg class="ic" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>Users</h2>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Username</th><th>Host</th><th>Databases</th><th>Reset password</th><th>Actions</th></tr></thead>
        <tbody>
          <% users.forEach(function(u) {
            var userGrants = typeof grants !== 'undefined' ? grants.filter(function(g){ return g.db_user_id === u.id; }) : [];
          %>
          <tr>
            <td><strong><%= u.username %></strong></td>
            <td><%= u.host %></td>
            <td>
              <div class="grant-list">
                <% if (userGrants.length) { userGrants.forEach(function(gr) { %>
                <span><%= gr.database_name %></span><span class="privilege-badge"><%= gr.privileges %></span>
                <% }); } else { %><span class="empty-msg">None</span><% } %>
              </div>
            </td>
            <td>
              <form method="post" action="/databases/users/<%= u.id %>/password" class="inline">
                <input type="password" name="password" placeholder="New password" class="input-small" required>
                <button type="submit" class="btn btn-small">Set</button>
              </form>
            </td>
            <td>
              <form method="post" action="/databases/users/<%= u.id %>/delete" class="inline" data-confirm="Delete user <%= u.username %>@<%= u.host %>? This will DROP the user in MySQL. Cannot be undone.">
                <button type="submit" class="btn btn-small btn-danger">Delete</button>
              </form>
            </td>
          </tr>
          <% }); %>
          <% if (!users.length) { %><tr><td colspan="5" class="empty-msg">None yet. Create one above.</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </main>
  <script src="/js/confirm-modal.js"></script>
</body>
</html>
