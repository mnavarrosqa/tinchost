<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'UPGS Panel' %></title>
  <link rel="stylesheet" href="/css/panel.css">
</head>
<body>
  <% if (typeof user !== 'undefined' && user) { %>
  <%- include('partials/nav') %>
  <% } %>
  <main<%= typeof mainClass !== 'undefined' && mainClass ? ' class="' + mainClass + '"' : '' %> id="main">
    <%- body %>
  </main>
  <script src="/js/toast.js"></script>
  <script>
    (function() {
      var m = /[?&]flash=([^&]+)/.exec(window.location.search);
      if (m && m[1] && window.toast) {
        try { window.toast.show(decodeURIComponent(m[1].replace(/\+/g, ' '))); } catch (_) {}
        if (window.history && window.history.replaceState) {
          var u = window.location.pathname + window.location.search.replace(/[?&]flash=[^&]+&?/, '?').replace(/\?$/, '');
          window.history.replaceState({}, '', u);
        }
      }
    })();
  </script>
</body>
</html>
